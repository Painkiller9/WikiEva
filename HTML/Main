<!DOCTYPE html> <!-- Объявление типа документа -->
<html lang="ru"> <!-- Корневой элемент страницы -->
<head>
    <meta charset="UTF-8"> <!-- Кодировка текста (обычно UTF-8) -->
    <title>Заголовок во вкладке браузера</title> <!-- Название страницы -->
</head>
<body>
    <h1>Привет, мир!</h1> <!-- Основной заголовок на странице -->
    <p>Это пример текста на HTML-странице.</p> <!-- Абзац текста -->
</body>
</html>